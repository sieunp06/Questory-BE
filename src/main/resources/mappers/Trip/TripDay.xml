<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.questory.trip.repository.TripDayRepository">
    <insert id="bulkInsert">
        INSERT INTO trip_day (trip_id, day_num, trip_date)
        VALUES
            <foreach collection="dates" item="date" index="idx" separator=",">
                (#{tripId}, #{idx} + 1, #{date})
            </foreach>
    </insert>
</mapper>