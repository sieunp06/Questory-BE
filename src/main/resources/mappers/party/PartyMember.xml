<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.questory.group.repository.PartyMemberRepository">
    <insert id="insert"
            parameterType="com.ssafy.questory.group.domain.PartyMember"
            useGeneratedKeys="true" keyProperty="partyId">
        INSERT INTO party_member (party_id, member_id, role, joined_at)
        VALUES (#{partyId}, #{memberId}, #{role}, #{joinedAt})
    </insert>
</mapper>