<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssafy.questory.group.repository.PartyRepository">
    <insert id="insert"
            parameterType="com.ssafy.questory.group.domain.Party"
            useGeneratedKeys="true" keyProperty="partyId">
        INSERT INTO party (name, creator_id, created_at)
        VALUES (#{name}, #{creatorId}, #{createdAt})
    </insert>
</mapper>